; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="末日搜打撤"
config/version="0.9.0"
run/main_scene="res://scenes/ui/main_menu.tscn"
config/features=PackedStringArray("4.7", "GL Compatibility")
config/icon="res://icon.svg"

[autoload]

EventBus="*res://autoloads/event_bus.gd"
RunRng="*res://autoloads/run_rng.gd"
RunState="*res://autoloads/run_state.gd"
Debug="*res://autoloads/debug.gd"
Sfx="*res://autoloads/sfx.gd"
GameSettings="*res://autoloads/game_settings.gd"
PauseMenu="*res://autoloads/pause_menu.gd"

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/stretch/mode="canvas_items"

[gui]

theme/custom_font="res://assets/fonts/fusion_pixel_12px_zh_hans.ttf"

